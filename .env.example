ENJOYTRIP_OAUTH2_GOOGLE_CLIENT_SECRET=
ENJOYTRIP_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback

# Local CDC / analytics stack (Postgres -> Debezium/Kafka Connect -> ClickHouse)
KAFKA_LOCAL_PORT=9092
KAFKA_CONNECT_PORT=8083
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_PASSWORD=enjoytrip_clickhouse
CDC_PUBLICATION_BOOTSTRAP_TIMEOUT_SECONDS=600
