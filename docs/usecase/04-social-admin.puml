@startuml 04-social-admin
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Apple SD Gothic Neo"
skinparam defaultFontSize 12
skinparam usecase {
  BackgroundColor #EFF6FF
  BorderColor #3B82F6
  FontColor #1E3A5F
  FontSize 12
}
skinparam actor {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
  FontColor #1E3A5F
  FontSize 13
}
skinparam rectangle {
  BackgroundColor #F8FAFF
  BorderColor #93C5FD
  BorderThickness 1.5
  FontColor #1D4ED8
  FontSize 13
  FontStyle bold
}
skinparam ArrowColor #6B7280

left to right direction

actor "회원\n(Member)" as Member
actor "관리자\n(Admin)" as Admin

Member -[hidden]d-> Admin

rectangle "친구" {
  usecase "친구 요청 보내기" as H1
  usecase "받은 친구 요청 수락" as H2
  usecase "받은 친구 요청 거절" as H3
  usecase "보낸 친구 요청 취소" as H4
  usecase "친구 삭제" as H5
  usecase "친구 목록 조회" as H6
  usecase "받은 요청 목록 조회" as H7
  usecase "보낸 요청 목록 조회" as H8
}

rectangle "알림" {
  usecase "알림 목록 조회" as I1
  usecase "읽지 않은 알림 여부 확인" as I2
}

rectangle "태그 관리" {
  usecase "태그 목록 조회" as J1
  usecase "태그 생성" as J2
  usecase "태그 수정" as J3
  usecase "태그 삭제" as J4
}

rectangle "관리자 패널" {
  usecase "관리자 로그인" as K1
  usecase "장소 관리" as K2
}

Member --> H1
Member --> H2
Member --> H3
Member --> H4
Member --> H5
Member --> H6
Member --> H7
Member --> H8
Member --> I1
Member --> I2
Member --> J1

Admin --> J2
Admin --> J3
Admin --> J4
Admin --> K1
Admin --> K2
@enduml
